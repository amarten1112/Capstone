# =============================================================================
# Virginia Market Square — .gitignore
# Place this file in the ROOT of your project (same folder as index.php)
# =============================================================================


# =============================================================================
# SECURITY CRITICAL — Never commit these
# These files contain passwords, API keys, and database credentials.
# If these ever land in a public GitHub repo it is a serious security breach.
# =============================================================================

# Database credentials + Stripe API keys live here
config.php

# If/when you move config.php into an includes/ subfolder later, also covered:
includes/config.php

# Generic environment variable files (common pattern, good habit to block)
.env
.env.local
.env.production


# =============================================================================
# COMPOSER — Vendor folder
# The /vendor/ directory contains all your Composer packages (Stripe SDK etc.)
# It can be 20–50MB and is regenerated by running: composer install
# GitHub Actions will install it fresh on every deploy — no need to commit it.
# =============================================================================

vendor/
composer.lock   # Optional: some teams commit this, but fine to exclude for now


# =============================================================================
# DATABASE EXPORTS — Don't commit backups or dumps with real customer data
# Your schema files (database.sql, seed_data.sql) are fine to commit
# since they only contain structure and fake test data — no real passwords.
# But exclude any backup dumps you create later with real data.
# =============================================================================

*.sql.bak
*.sql.backup
*_backup.sql
*_dump.sql


# =============================================================================
# LOG FILES — Generated at runtime, not part of source code
# =============================================================================

*.log
/logs/
/log/
error_log
php_error.log


# =============================================================================
# IMAGE UPLOADS (future) — Uploaded by vendors/admin at runtime
# If you add a file upload feature later, user-uploaded images should NOT
# be in version control. Add those upload folder paths here when ready.
# Example (uncomment when you have an uploads folder):
# /uploads/
# /images/uploads/
# =============================================================================


# =============================================================================
# OS & EDITOR CLUTTER — Files your OS or IDE creates automatically
# These have nothing to do with your project and just add noise to git.
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VSCode (remove these two lines if you WANT to share editor settings with teammates)
.vscode/
*.code-workspace

# PhpStorm / JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace


# =============================================================================
# XAMPP / LOCAL DEV ARTIFACTS
# =============================================================================

# XAMPP sometimes creates these in project folders
/xampp/
apache_pb.gif


# =============================================================================
# CLAUDE CODE — AI assistant local config, not needed in repo
# =============================================================================

.claude/


# =============================================================================
# TEMP & BUILD FILES
# =============================================================================

*.tmp
*.temp
*.swp
*.swo
*~
.cache/
